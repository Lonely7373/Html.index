<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mortal Escrow | Secure the Past. Reclaim Future.</title>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

    <style>
        /* --- CSS VARIABLES & RESET --- */
        :root {
            --bg-color: #0a0a0a;
            --card-bg: #141414;
            --text-main: #e5e5e5;
            --text-muted: #a0a0a0;
            --accent-gold: #C5A059;
            --accent-gold-hover: #d4b06a;
            --accent-red: #8a0303;
            --font-heading: 'Cinzel', serif;
            --font-body: 'Inter', sans-serif;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-main);
            font-family: var(--font-body);
            line-height: 1.6;
            overflow-x: hidden;
        }

        a { text-decoration: none; color: inherit; transition: 0.3s; }
        ul { list-style: none; }

        /* --- UTILITIES --- */
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
        }

        .gold-text { color: var(--accent-gold); }
        .text-center { text-align: center; }

        /* --- HEADER --- */
        header {
            position: fixed;
            top: 0;
            width: 100%;
            background: rgba(10, 10, 10, 0.95);
            border-bottom: 1px solid #222;
            z-index: 1000;
            padding: 20px 0;
        }

        nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo {
            font-family: var(--font-heading);
            font-size: 1.5rem;
            font-weight: 700;
            letter-spacing: 2px;
            color: var(--text-main);
        }

        .logo span { color: var(--accent-gold); }

        .nav-links {
            display: flex;
            gap: 30px;
        }

        .nav-links a {
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--text-muted);
        }

        .nav-links a:hover { color: var(--accent-gold); }

        .cta-btn {
            background: transparent;
            border: 1px solid var(--accent-gold);
            color: var(--accent-gold);
            padding: 10px 25px;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            cursor: pointer;
            transition: 0.3s;
        }

        .cta-btn:hover {
            background: var(--accent-gold);
            color: var(--bg-color);
        }

        /* --- HERO SECTION --- */
        .hero {
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            background: radial-gradient(circle at center, #1a1a1a 0%, #0a0a0a 100%);
            position: relative;
        }

        .hero::before {
            content: '';
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background: url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSI0IiBoZWlnaHQ9IjQiPgo8cmVjdCB3aWR0aD0iNCIgaGVpZ2h0PSI0IiBmaWxsPSIjMGEwYTBhIi8+CjxyZWN0IHdpZHRoPSIxIiBoZWlnaHQ9IjEiIGZpbGw9IiMxYTFhMWEiLz4KPC9zdmc+');
            opacity: 0.1;
        }

        .hero-content {
            z-index: 2;
            max-width: 800px;
            padding: 20px;
        }

        .hero h1 {
            font-family: var(--font-heading);
            font-size: 3.5rem;
            margin-bottom: 20px;
            line-height: 1.2;
        }

        .hero p {
            font-size: 1.2rem;
            color: var(--text-muted);
            margin-bottom: 40px;
            font-weight: 300;
        }

        .hero-tagline {
            font-size: 1.5rem;
            color: var(--accent-gold);
            margin-bottom: 30px;
            letter-spacing: 3px;
            text-transform: uppercase;
        }

        /* --- ABOUT / MANIFESTO --- */
        .manifesto {
            padding: 100px 0;
            background: var(--card-bg);
            border-top: 1px solid #222;
            border-bottom: 1px solid #222;
        }

        .manifesto h2 {
            font-family: var(--font-heading);
            font-size: 2.5rem;
            margin-bottom: 30px;
            text-align: center;
        }

        .manifesto p {
            max-width: 700px;
            margin: 0 auto;
            text-align: center;
            color: var(--text-muted);
            font-size: 1.1rem;
        }

        /* --- PROCESS --- */
        .process {
            padding: 100px 0;
        }

        .section-header {
            text-align: center;
            margin-bottom: 60px;
        }

        .section-header h2 {
            font-family: var(--font-heading);
            font-size: 2.5rem;
            margin-bottom: 10px;
        }

        .grid-3 {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 40px;
        }

        .card {
            background: var(--card-bg);
            padding: 40px;
            border: 1px solid #222;
            transition: 0.3s;
            position: relative;
            overflow: hidden;
        }

        .card:hover {
            border-color: var(--accent-gold);
            transform: translateY(-5px);
        }

        .card-number {
            font-family: var(--font-heading);
            font-size: 3rem;
            color: #222;
            position: absolute;
            top: 10px;
            right: 20px;
            opacity: 0.5;
        }

        .card h3 {
            font-size: 1.2rem;
            margin-bottom: 15px;
            color: var(--accent-gold);
        }

        .card p {
            color: var(--text-muted);
            font-size: 0.95rem;
        }

        /* --- CONTACT FORM --- */
        .contact {
            padding: 100px 0;
            background: linear-gradient(to bottom, var(--bg-color), #111);
        }

        .form-box {
            max-width: 600px;
            margin: 0 auto;
            background: var(--card-bg);
            padding: 40px;
            border: 1px solid #222;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-size: 0.9rem;
            color: var(--text-muted);
        }

        .form-group input, .form-group select, .form-group textarea {
            width: 100%;
            padding: 12px;
            background: #0a0a0a;
            border: 1px solid #333;
            color: var(--text-main);
            font-family: var(--font-body);
        }

        .form-group input:focus, .form-group textarea:focus {
            outline: none;
            border-color: var(--accent-gold);
        }

        .submit-btn {
            width: 100%;
            padding: 15px;
            background: var(--accent-gold);
            color: var(--bg-color);
            border: none;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            cursor: pointer;
            transition: 0.3s;
        }

        .submit-btn:hover {
            background: var(--accent-gold-hover);
        }

        /* --- FOOTER --- */
        footer {
            padding: 50px 0;
            border-top: 1px solid #222;
            text-align: center;
            font-size: 0.8rem;
            color: #555;
        }

        .footer-logo {
            font-family: var(--font-heading);
            color: var(--text-main);
            margin-bottom: 20px;
            display: block;
        }

        .disclaimer {
            max-width: 600px;
            margin: 20px auto 0;
            font-size: 0.7rem;
            line-height: 1.4;
        }

        /* --- RESPONSIVE --- */
        @media (max-width: 768px) {
            .hero h1 { font-size: 2.5rem; }
            .nav-links { display: none; } /* Simplified for demo */
            .grid-3 { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>

    <!-- Header -->
    <header>
        <div class="container">
            <nav>
                <a href="#" class="logo">MORTAL <span>ESCROW</span></a>
                <ul class="nav-links">
                    <li><a href="#about">Philosophy</a></li>
                    <li><a href="#process">Protocol</a></li>
                    <li><a href="#contact">Secure Intake</a></li>
                </ul>
                <a href="#contact" class="cta-btn">Initiate Protocol</a>
            </nav>
        </div>
    </header>

    <!-- Hero Section -->
    <section class="hero">
        <div class="hero-content">
            <div class="hero-tagline">Secure the Past. Reclaim Future.</div>
            <h1>Your Digital Legacy is Mortal.<br>Your Recovery is Eternal.</h1>
            <p>The world's premier escrow service for high-stakes social media recovery. We secure your assets, verify your identity, and reclaim your digital life.</p>
            <a href="#contact" class="cta-btn" style="background: var(--accent-gold); color: #000;">Start Recovery</a>
        </div>
    </section>

    <!-- Manifesto Section -->
    <section id="about" class="manifesto">
        <div class="container">
            <h2>The Trust Deficit</h2>
            <p>
                In a world of bots and scammers, trust is the most valuable currency. Standard support channels are broken. 
                We bridge the gap between you and the platform administrators using verified legal frameworks and direct negotiation.
                <br><br>
                <strong>We do not guess. We verify. We do not rush. We secure.</strong>
            </p>
        </div>
    </section>

    <!-- Process Section -->
    <section id="process" class="process">
        <div class="container">
            <div class="section-header">
                <h2>The Protocol</h2>
                <p style="color: var(--text-muted);">How we operate on strict escrow terms.</p>
            </div>
            <div class="grid-3">
                <!-- Step 1 -->
                <div class="card">
                    <span class="card-number">01</span>
                    <h3>The Vault</h3>
                    <p>Funds are held in a secure, third-party escrow account. We do not touch your money until the account is verified as recoverable.</p>
                </div>
                <!-- Step 2 -->
                <div class="card">
                    <span class="card-number">02</span>
                    <h3>The Audit</h3>
                    <p>Our forensic team analyzes the breach vector, gathers necessary proof of ownership, and prepares the legal case file.</p>
                </div>
                <!-- Step 3 -->
                <div class="card">
                    <span class="card-number">03</span>
                    <h3>The Handover</h3>
                    <p>Upon successful recovery, the escrow is released, and you regain full control. No recovery, no fee.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Contact Section -->
    <section id="contact" class="contact">
        <div class="container">
            <div class="section-header">
                <h2>Secure Intake</h2>
                <p style="color: var(--text-muted);">All data is encrypted via AES-256. Your case is anonymous until the contract is signed.</p>
            </div>
            <div class="form-box">
                <form id="recoveryForm">
                    <div class="form-group">
                        <label>Platform</label>
                        <select>
                            <option>Instagram</option>
                            <option>X (Twitter)</option>
                            <option>Facebook</option>
                            <option>TikTok</option>
                            <option>Other</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Account URL (Public)</label>
                        <input type="text" placeholder="https://..." required>
                    </div>
                    <div class="form-group">
                        <label>Nature of Loss</label>
                        <select>
                            <option>Hacked / Unauthorized Access</option>
                            <option>Phishing Attack</option>
                            <option>Forgotten Credentials</option>
                            <option>Identity Theft</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Proof of Ownership (Email/ID)</label>
                        <input type="file" style="border: 1px solid #333; padding: 10px; background: #0a0a0a; color: #555;">
                    </div>
                    <button type="submit" class="submit-btn">Initiate Recovery Protocol</button>
                </form>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer>
        <div class="container">
            <span class="footer-logo">MORTAL ESCROW</span>
            <p>Secure the Past. Reclaim Future.</p>
            <div class="disclaimer">
                <p>© 2024 Mortal Escrow. All Rights Reserved.</p>
                <p>Disclaimer: Mortal Escrow operates as a digital recovery consultancy. We do not hack. We utilize legal frameworks, Terms of Service appeals, and identity verification protocols to reclaim your property. All services are subject to Terms of Service.</p>
            </div>
        </div>
    </footer>

   
